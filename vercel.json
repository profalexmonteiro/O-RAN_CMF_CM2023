{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/start.py": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/web/index.html"
    },
    {
      "source": "/app.js",
      "destination": "/web/app.js"
    },
    {
      "source": "/style.css",
      "destination": "/web/style.css"
    }
  ]
}
